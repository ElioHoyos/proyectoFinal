<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.Bienvenido">
    <ContentPage.Content>
        <StackLayout Background="#009491">
            <Frame Background="black" VerticalOptions="CenterAndExpand" 
                HorizontalOptions="CenterAndExpand" CornerRadius="20" Margin="20,80,20,100">
                <StackLayout>
                    <Label TextColor="White" x:Name="LabelNombre" FontSize="30"></Label>
                    <Label TextColor="White" x:Name="LabelCorreo" FontSize="30"></Label>
                    <Image Source="https://www.eltiempo.com/files/image_1200_680/uploads/2019/12/07/5dec47012d257.jpeg"></Image>
                    <Button Background="#58D7DB" Text="Ir al Sistema" FontAttributes="Bold" FontSize="20" Margin="0,40,0,40" CornerRadius="20" Clicked="Button1_Clicked"/>
                </StackLayout>
            </Frame>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>